# ============================================
# Anime Pro Backend — Environment Configuration
# ============================================

# Database (Neon PostgreSQL - Free Tier)
# 1. Go to https://neon.tech and sign up (free)
# 2. Create a new project (e.g., "anime-pro")
# 3. Copy the connection string from the dashboard
# 4. It looks like: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# JWT Secret — Used to sign authentication tokens
# Generate a strong random secret (at least 32 characters)
# If left empty, a random one is generated at startup (won't survive restarts)
JWT_SECRET=

# Server Port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
