{
    "name": "jikan-backend",
    "version": "1.0.0",
    "description": "Standalone Jikan API backend for anime streaming platform",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "test": "npx tsx src/test-jikan.ts",
        "typecheck": "tsc --noEmit",
        "format": "prettier --cache --write .",
        "format:check": "prettier --cache --check ."
    },
    "keywords": [
        "jikan",
        "myanimelist",
        "anime",
        "api",
        "streaming"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "22": "^0.0.0",
        "@hono/node-server": "^1.13.0",
        "@modelcontextprotocol/sdk": "^1.0.4",
        "@testsprite/testsprite-mcp": "^0.0.32",
        "cheerio": "^1.2.0",
        "hono": "^4.5.10",
        "latest": "^0.2.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "prettier": "^3.3.3",
        "tsx": "^4.19.1",
        "typescript": "^5.7.3"
    }
}