{
  "name": "anime-pro-monorepo",
  "private": true,
  "workspaces": [
    "sveltekit-frontend",
    "android-app",
    "desktop-app"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=sveltekit-frontend",
    "check": "npm run check --workspace=sveltekit-frontend",
    "build": "npm run build --workspace=sveltekit-frontend",
    "seo:verify": "node scripts/seo/verify-production.mjs",
    "seo:indexnow": "node scripts/seo/submit-indexnow.mjs",
    "seo:indexnow:dry": "set INDEXNOW_DRY_RUN=1&& node scripts/seo/submit-indexnow.mjs",
    "dev:backend": "go run ./backend-go/cmd/server",
    "test:backend": "cd backend-go && go test ./...",
    "build:backend": "cd backend-go && go build ./cmd/server",
    "tv:analyze": "cd anime_pro_tv && flutter analyze",
    "tv:test": "cd anime_pro_tv && flutter test",
    "tv:run": "cd anime_pro_tv && flutter run",
    "tv:build:apk": "cd anime_pro_tv && flutter build apk"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
