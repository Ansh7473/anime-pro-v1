# Cloudflare Pages static asset cache headers
# (Does NOT affect SSR/Worker responses — those are controlled by SvelteKit.)

# Fingerprinted build assets — content-hashed, safe to cache 1 year (immutable)
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker — must always be fresh to trigger updates
/sw.js
  Cache-Control: no-cache

# Static images and media — cache 1 day at edge
/*.png
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
/*.mp4
  Cache-Control: public, max-age=86400

# Web manifest — cache 1 hour
/manifest.json
  Cache-Control: public, max-age=3600
